{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["local>NethServer/.github:vue3"],
  "packageRules": [
    {
      "description": "Node.js and its types should be updated together and respect the OpenWRT version where it's built on.",
      "matchPackageNames": ["node", "@types/node"],
      "allowedVersions": "<= 22.22.2"
    },
    {
      "matchDatasources": ["npm"],
      "matchUpdateTypes": ["lockFileMaintenance"],
      "automerge": true
    }
  ]
}
